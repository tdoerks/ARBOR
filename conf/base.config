/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    tdoerks/arbor Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + (175..177)) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Process-specific resource requirements — sized for VIRAL amplicon data (~12 kb genomes,
    // small BAMs). Deliberately small so jobs schedule fast on a busy cluster; bump per-tool below.
    withLabel:process_single {
        cpus   = { 1                  }
        memory = { 2.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2    * task.attempt }
        memory = { 4.GB * task.attempt }
        time   = { 3.h  * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 2     * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 4     * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 6.h   * task.attempt }
    }
    withLabel:process_long {
        time   = { 12.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 24.GB * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }

    // arbor per-tool sizing — viral data is tiny; these are the (slightly) heavier steps
    withName: 'LOFREQ_CALL' {
        cpus   = { 2 }
        memory = { 8.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withName: 'IQTREE' {
        cpus   = { 2 }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
}
